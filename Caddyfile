{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# MinIO Web Console (administración del storage)
	handle /console* {
		reverse_proxy minio:9001
	}

	# MinIO S3 API (uploads/downloads directos vía SDK o mc/aws-cli)
	handle_path /s3* {
		reverse_proxy minio:9000
	}

	# imgproxy = reemplazo de Cloudinary (transformación on-the-fly)
	handle {
		reverse_proxy imgproxy:8080
	}

	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}
}
