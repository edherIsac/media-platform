# ===== Reemplazo de Cloudinary (self-hosted media platform) =====

# Dominio público del VPS (Caddy gestionará TLS automáticamente)
DOMAIN=media.tudominio.com
ACME_EMAIL=admin@tudominio.com

# --- MinIO (storage S3-compatible) ---
# Root user/pass: MÍNIMO 8 caracteres. Usar valores fuertes en producción.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=cambia-esto-por-una-clave-fuerte

# Bucket por defecto donde imgproxy leerá las imágenes
S3_BUCKET=media

# Región AWS-style (cosmético pero requerido)
AWS_REGION=us-east-1

# --- imgproxy (transformación on-the-fly) ---
# Genera estas claves con: openssl rand -hex 16   (una para KEY y otra para SALT)
IMGPROXY_KEY=
IMGPROXY_SALT=

# En desarrollo úsalo en true para no tener que firmar URLs
# En producción DEBE ser false (firmar todas las URLs)
IMGPROXY_ALLOW_INSECURE=false

# TTL de cache de las imágenes transformadas (segundos). Default: 1 año
IMGPROXY_TTL=31536000
